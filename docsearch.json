{
  "custom_settings": {
    "separatorsToIndex": "_",
    "attributesForFaceting": ["language", "version", "type", "lang"],
    "attributesToRetrieve": [
      "hierarchy",
      "content",
      "anchor",
      "url",
      "url_without_anchor",
      "type"
    ]
  },
  "index_name": "manael",
  "selectors": {
    "lvl0": {
      "selector": ".td-sidebar-nav .active",
      "type": "css",
      "global": true,
      "default_value": "Documentation"
    },
    "lvl1": "article h1",
    "lvl2": "article h2",
    "lvl3": "article h3",
    "lvl4": "article h4",
    "lvl5": "article h5",
    "lvl6": "article h6",
    "text": "article p, article li"
  },
  "sitemap_alternate_links": true,
  "sitemap_urls": ["https://manael.org/sitemap.xml"],
  "start_urls": ["https://manael.org/"],
  "strip_chars": " .,;:#",
  "stop_urls": []
}
