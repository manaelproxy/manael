# URL of the upstream image server that Manael proxies to.
MANAEL_UPSTREAM_URL=http://localhost:9000

# Set to "true" to enable on-the-fly image resizing via ?w=, ?h=, and ?fit= query parameters.
MANAEL_ENABLE_RESIZE=false

# Set to "true" to enable AVIF encoding in addition to WebP.
MANAEL_ENABLE_AVIF=false

# Maximum allowed image size (in bytes) fetched from the upstream server. Default: 20971520 (20 MiB).
# MANAEL_MAX_IMAGE_SIZE=20971520

# Maximum allowed resize width in pixels.
# MANAEL_MAX_RESIZE_WIDTH=2000

# Maximum allowed resize height in pixels.
# MANAEL_MAX_RESIZE_HEIGHT=2000

# Comma-separated list of allowed resize widths. Requests for other widths are rejected.
# MANAEL_ALLOWED_WIDTHS=320,640,1280,1920

# Comma-separated list of allowed resize heights. Requests for other heights are rejected.
# MANAEL_ALLOWED_HEIGHTS=240,480,720,1080

# Default image quality (1-100). Applies when the ?q= parameter is not provided.
# MANAEL_DEFAULT_QUALITY=85

# Port to listen on. Defaults to 8080.
# PORT=8080

# Port on which Prometheus metrics are exposed (e.g. 9090). Leave unset to disable metrics.
# MANAEL_METRICS_PORT=9090
